<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-6">
      <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-4">
          <h2 class="card-title text-center fw-bold mb-4">Add a New Restaurant</h2>

          <!-- Simple form automatically maps to our Restaurant model -->
          <%= simple_form_for(@restaurant) do |f| %>
            <%= f.input :name, placeholder: "e.g. Epicure" %>
            <%= f.input :address, placeholder: "e.g. 112 Rue du Faubourg Saint-Honoré, Paris" %>
            <%= f.input :phone_number, placeholder: "e.g. +33 1 53 43 43 40" %>
            <%= f.input :category, collection: ["chinese", "italian", "japanese", "french", "belgian"], prompt: "Select a category" %>

            <%= f.submit "Create Restaurant", class: "btn btn-primary w-100 mt-4 fw-bold" %>
          <% end %>

          <div class="mt-3 text-center">
            <%= link_to "Cancel", restaurants_path, class: "text-muted text-decoration-none" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
