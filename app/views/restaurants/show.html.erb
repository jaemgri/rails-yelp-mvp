<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8">
      <div class="card shadow-sm">
        <div class="card-body p-5">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="card-title fw-bold mb-0"><%= @restaurant.name %></h1>
            <span class="badge bg-primary fs-6"><%= @restaurant.category.capitalize %></span>
          </div>

          <p class="card-text fs-5"><i class="fas fa-map-marker-alt text-muted"></i> <%= @restaurant.address %></p>
          <p class="card-text fs-5"><i class="fas fa-phone text-muted"></i> <%= @restaurant.phone_number %></p>

          <hr class="my-4">

          <!-- Reviews Section -->
          <h3 class="mb-3">Reviews</h3>
          <% if @restaurant.reviews.empty? %>
            <p class="text-muted">No reviews yet. Be the first!</p>
          <% else %>
            <ul class="list-group list-group-flush mb-4">
              <% @restaurant.reviews.each do |review| %>
                <li class="list-group-item">
                  <div class="d-flex justify-content-between">
                    <strong>Rating: <%= review.rating %> / 5</strong>
                  </div>
                  <p class="mb-0"><%= review.content %></p>
                </li>
              <% end %>
            </ul>
          <% end %>

          <%= link_to "Add a review", new_restaurant_review_path(@restaurant), class: "btn btn-outline-primary mb-3" %>
          <br>
          <%= link_to "Back to all restaurants", restaurants_path, class: "btn btn-outline-secondary" %>
        </div>
      </div>
    </div>
  </div>
</div>
